{
  "manifest_version": 2,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "6.0.0",
  "applications": {
    "gecko": {
      "id": "shrunked@darktrojan.net",
      "strict_min_version": "140.0",
      "strict_max_version": "*"
    }
  },
  "author": "Geoff Lankow",
  "homepage_url": "https://github.com/darktrojan/shrunked",
  "icons": {
    "16": "content/icon16.png",
    "32": "content/icon32.png",
    "64": "content/icon64.png"
  },
  "default_locale": "en",
  "background": {
    "scripts": [
      "background.js",
      "modules/ShrunkedImage.js",
      "modules/ExifData.js"
    ]
  },
  "permissions": [
    "compose",
    "storage",
    "tabs"
  ],
  "options_ui": {
    "page": "content/config.xhtml"
  },
  "compose_action": {
    "default_icon": {
      "16": "content/icon16.png",
      "32": "content/icon32.png",
      "64": "content/icon64.png"
    },
    "default_label": "Resize images",
    "default_popup": "content/options.xhtml"
  }
}
